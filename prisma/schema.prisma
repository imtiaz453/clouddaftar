  expectedDate    DateTime?
  status          String    @default("PENDING") // PENDING, PARTIALLY_FULFILLED, FULFILLED, CANCELLED
  notes           String?
  fulfilledAmount Decimal   @default(0)
  fulfilledAt     DateTime?
  createdById     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer  Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  supplier  Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdBy User      @relation(fields: [createdById], references: [id])

  @@index([companyId])
  @@index([customerId])
  @@index([supplierId])
  @@index([status])
  @@index([commitmentDate])
  @@map("payment_commitments")
}

enum SystemAdminRole {
  OWNER
  SUPER_ADMIN
  BILLING_ADMIN
  SUPPORT_ADMIN
}

model SystemAdmin {
  id           String          @id @default(cuid())
  name         String
  email        String          @unique
  passwordHash String
  role         SystemAdminRole @default(SUPER_ADMIN)
  avatar       String?
  isActive     Boolean         @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  sessions         SystemAdminSession[]
  auditLogs        SystemAdminAuditLog[]
  verifiedInvoices BillingInvoice[]      @relation("InvoiceVerifiedBy")
  verifiedPayments PaymentSubmission[]   @relation("PaymentVerifiedBy")

  @@index([email])
  @@map("system_admins")
}

model SystemAdminSession {
  id        String   @id @default(cuid())
  adminId   String
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  admin SystemAdmin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([adminId])
  @@index([expiresAt])
  @@map("system_admin_sessions")
}

model SystemAdminAuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  admin SystemAdmin @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([createdAt])
  @@index([action])
  @@map("system_admin_audit_logs")
}

model CoaAccount {
  id          String      @id @default(cuid())
  code        String
  name        String
  type        AccountType
  parentId    String?
  description String?
  companyId   String
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent       CoaAccount?        @relation("CoaAccountHierarchy", fields: [parentId], references: [id])
  children     CoaAccount[]       @relation("CoaAccountHierarchy")
  journalLines JournalEntryLine[]
  salaryRules  SalaryRule[]

  @@unique([code, companyId])
  @@index([companyId])
  @@index([parentId])
  @@index([type])
  @@map("coa_accounts")
}

model JournalEntryMaster {
  id          String      @id @default(cuid())
  number      String
  date        DateTime
  reference   String?
  description String?
  journalType JournalType @default(GENERAL)
  companyId   String
  createdById String
  isPosted    Boolean     @default(false)
  postedAt    DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  company   Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User               @relation(fields: [createdById], references: [id])
  lines     JournalEntryLine[]

  @@unique([number, companyId])
  @@index([companyId])
  @@index([date])
  @@index([journalType])
  @@index([isPosted])
  @@map("journal_entry_masters")
}

model JournalEntryLine {
  id             String  @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Decimal @default(0)
  credit         Decimal @default(0)
  partnerId      String?
  description    String?

  journalEntry JournalEntryMaster @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      CoaAccount         @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
  @@index([partnerId])
  @@map("journal_entry_lines")
}

enum WageType {
  MONTHLY
  HOURLY
  DAILY
}

enum SalaryRuleCategory {
  BASIC
  ALLOWANCE
  DEDUCTION
  EMPLOYER_CONTRIBUTION
  NET
}

enum PayslipStatus {
  DRAFT
  VERIFIED
  APPROVED
  PAID
  CANCELLED
}

enum PayslipBatchStatus {
  DRAFT
  VERIFIED
  APPROVED
  PAID
  CANCELLED
}

model Contract {
  id         String    @id @default(cuid())
  employeeId String
  companyId  String
  wageType   WageType  @default(MONTHLY)
  wage       Decimal   @default(0)
  startDate  DateTime
  endDate    DateTime?
  schedule   String?   @default("Monthly")
  structure  String?   @default("Monthly Employee")
  isActive   Boolean   @default(true)
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  employee User    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  payslips Payslip[]

  @@index([employeeId])
  @@index([companyId])
  @@index([isActive])
  @@map("contracts")
}

model SalaryRule {
  id            String             @id @default(cuid())
  code          String
  name          String
  category      SalaryRuleCategory @default(ALLOWANCE)
  sequence      Int                @default(10)
  condition     String?            @default("True")
  amountFixed   Decimal            @default(0)
  amountPercent Decimal            @default(0)
  basedOn       String?            @default("contract.wage")
  accountId     String?
  companyId     String
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  account      CoaAccount?   @relation(fields: [accountId], references: [id], onDelete: SetNull)
  payslipLines PayslipLine[]

  @@unique([code, companyId])
  @@index([companyId])
  @@index([category])
  @@map("salary_rules")
}

model Payslip {
  id              String        @id @default(cuid())
  number          String
  employeeId      String
  contractId      String
  companyId       String
  batchId         String?
  dateFrom        DateTime
  dateTo          DateTime
  status          PayslipStatus @default(DRAFT)
  grossPay        Decimal       @default(0)
  totalDeductions Decimal       @default(0)
  netPay          Decimal       @default(0)
  employerCost    Decimal       @default(0)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  employee    User               @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  contract    Contract           @relation(fields: [contractId], references: [id])
  batch       PayrollBatch?      @relation(fields: [batchId], references: [id])
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines       PayslipLine[]
  adjustments SalaryAdjustment[]

  @@unique([number, companyId])
  @@index([employeeId])
  @@index([contractId])
  @@index([batchId])
  @@index([companyId])
  @@index([dateFrom, dateTo])
  @@map("payslips")
}

model PayslipLine {
  id           String             @id @default(cuid())
  payslipId    String
  salaryRuleId String?
  code         String
  name         String
  category     SalaryRuleCategory
  amount       Decimal            @default(0)
  total        Decimal            @default(0)
  sequence     Int                @default(10)

  payslip    Payslip     @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  salaryRule SalaryRule? @relation(fields: [salaryRuleId], references: [id], onDelete: SetNull)

  @@index([payslipId])
  @@map("payslip_lines")
}

model PayrollBatch {
  id          String             @id @default(cuid())
  name        String
  dateFrom    DateTime
  dateTo      DateTime
  status      PayslipBatchStatus @default(DRAFT)
  companyId   String
  createdById String
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdById], references: [id])
  payslips  Payslip[]

  @@index([companyId])
  @@index([status])
  @@map("payroll_batches")
}

model WorkEntry {
  id         String   @id @default(cuid())
  employeeId String
  companyId  String
  date       DateTime
  workType   String?  @default("PRESENT")
  hours      Float?   @default(8)
  dayRate    Decimal? @default(0)
  leaveType  String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee User    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([companyId])
  @@index([date])
  @@map("work_entries")
}

model SalaryAdjustment {
  id         String             @id @default(cuid())
  employeeId String
  companyId  String
  name       String
  type       SalaryRuleCategory @default(ALLOWANCE)
  amount     Decimal            @default(0)
  date       DateTime
  recurring  Boolean            @default(false)
  notes      String?
  payslipId  String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  employee User     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payslip  Payslip? @relation(fields: [payslipId], references: [id], onDelete: SetNull)

  @@index([employeeId])
  @@index([companyId])
  @@index([date])
  @@map("salary_adjustments")
}

enum EquipmentStatus {
  ASSIGNED
  AVAILABLE
  MAINTENANCE
  RETIRED
}

model EmployeeEquipment {
  id           String          @id @default(cuid())
  name         String
  serialNumber String?
  category     String?
  status       EquipmentStatus @default(AVAILABLE)
  assignedToId String?
  assignedAt   DateTime?
  returnedAt   DateTime?
  notes        String?
  companyId    String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  assignedTo User?   @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([assignedToId])
  @@index([status])
  @@map("employee_equipment")
}

model EmployeeCertification {
  id           String    @id @default(cuid())
  employeeId   String
  name         String
  issuer       String?
  issueDate    DateTime?
  expiryDate   DateTime?
  referenceUrl String?
  companyId    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  employee User    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([companyId])
  @@map("employee_certifications")
}
