generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleType {
  OWNER
  ADMIN
  MANAGER
  STAFF
  CASHIER
}

enum StoreType {
  MAIN_WAREHOUSE
  POS_STORE
  EMPLOYEE_STORE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum SaleStatus {
  DRAFT
  CONFIRMED
  PROFORMA
  COMPLETED
  PARTIALLY_REFUNDED
  REFUNDED
  CANCELLED
}

enum PurchaseStatus {
  DRAFT
  PENDING
  RECEIVED
  PARTIALLY_RECEIVED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  MOBILE_PAYMENT
  CHEQUE
  EASYPAISA
  JAZZCASH
  ONLINE_TRANSFER
  OTHER
}

enum SalePaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  CANCELLED
  RETURNED
}

enum PurchasePaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  CANCELLED
  RETURNED
}

enum ProductTrackingMode {
  NONE
  LOT
  SERIAL
  BATCH
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PAID
}

enum LedgerEntryType {
  INVOICE
  PURCHASE
  PAYMENT
  RETURN
  ADJUSTMENT
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
  CONTRA_ASSET
  CONTRA_LIABILITY
  CONTRA_INCOME
  CONTRA_EXPENSE
}

enum JournalType {
  GENERAL
  SALES
  PURCHASES
  CASH
  BANK
  RECEIPT
  PAYMENT
  SALARY
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  READ
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  ENABLE
  DISABLE
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ERROR
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum PaymentStatus {
  PENDING
  SUBMITTED
  CONFIRMED
  REJECTED
  EXPIRED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  phone         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  companies                  CompanyMembership[]
  activities                 ActivityLog[]
  notifications              Notification[]
  auditLogs                  AuditLog[]
  createdSales               Sale[]                  @relation("SaleCreatedBy")
  updatedSales               Sale[]                  @relation("SaleUpdatedBy")
  createdPurchases           Purchase[]              @relation("PurchaseCreatedBy")
  updatedPurchases           Purchase[]              @relation("PurchaseUpdatedBy")
  sentInvitations            Invitation[]            @relation("InvitationSentBy")
  systemAuditLogs            SystemAuditLog[]
  accounts                   Account[]
  sessions                   Session[]
  activeLoginSessions        ActiveLoginSession[]
  passwordResetCodes         PasswordResetCode[]
  createdPayments            Payment[]
  createdLedgerEntries       LedgerEntry[]
  createdReminders           PaymentReminder[]
  createdReconciliations     Reconciliation[]
  createdBalanceAdjustments  BalanceAdjustment[]
  reversedBalanceAdjustments BalanceAdjustment[]     @relation("ReversedBy")
  createdCommitments         PaymentCommitment[]
  createdQuotations          Quotation[]             @relation("QuotationCreatedBy")
  updatedQuotations          Quotation[]             @relation("QuotationUpdatedBy")
  expenses                   Expense[]               @relation("ExpenseEmployee")
  approvedExpenses           Expense[]               @relation("ExpenseApprovedBy")
  createdJournalEntries      JournalEntryMaster[]
  equipment                  EmployeeEquipment[]
  certifications             EmployeeCertification[]
  contracts                  Contract[]
  payslips                   Payslip[]
  createdBatches             PayrollBatch[]
  workEntries                WorkEntry[]
  salaryAdjustments          SalaryAdjustment[]
  createdInventoryLogs       InventoryLog[]          @relation("InventoryLogCreatedBy")
  employeeRecord             EmployeeRecord?
  assignedStores             Warehouse[]             @relation("WarehouseAssignedEmployee")
  pushSubscriptions          PushSubscription[]

  @@index([email])
  @@map("users")
}

model Company {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  logo            String?
  website         String?
  phone           String?
  email           String?
  address         String?
  city            String?
  state           String?
  zipCode         String?
  country         String    @default("PK")
  taxId           String?
  taxName         String?
  taxRate         Float     @default(0)
  currency        String    @default("PKR")
  currencySymbol  String    @default("Rs")
  timezone        String    @default("Asia/Karachi")
  dateFormat      String    @default("DD/MM/YYYY")
  fiscalYearStart String    @default("01-01")
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  members                 CompanyMembership[]
  branches                Branch[]
  warehouses              Warehouse[]
  productStocks           ProductStock[]
  warehouseLocations      WarehouseLocation[]
  categories              Category[]
  products                Product[]
  customers               Customer[]
  suppliers               Supplier[]
  sales                   Sale[]
  purchases               Purchase[]
  inventoryLogs           InventoryLog[]
  templates               InvoiceTemplate[]
  theme                   ThemeSettings?
  settings                CompanySettings?
  notifications           Notification[]
  invitations             Invitation[]
  units                   Unit[]
  auditLogs               AuditLog[]
  activityLogs            ActivityLog[]
  subscription            TenantSubscription?
  invoices                BillingInvoice[]
  payments                PaymentSubmission[]
  companyPayments         Payment[]
  ledgerEntries           LedgerEntry[]
  reminders               PaymentReminder[]
  reconciliations         Reconciliation[]
  balanceAdjustments      BalanceAdjustment[]
  paymentCommitments      PaymentCommitment[]
  quotations              Quotation[]
  documentNumberSequences DocumentNumberSequence[]
  expenses                Expense[]
  coaAccounts             CoaAccount[]
  journalEntryMasters     JournalEntryMaster[]
  employeeEquipment       EmployeeEquipment[]
  employeeCertifications  EmployeeCertification[]
  contracts               Contract[]
  salaryRules             SalaryRule[]
  payslips                Payslip[]
  payrollBatches          PayrollBatch[]
  workEntries             WorkEntry[]
  salaryAdjustments       SalaryAdjustment[]
  productLots             ProductLot[]
  productLotStocks        ProductLotStock[]
  zatcaEgsUnits           ZatcaEgsUnit[]
  zatcaSetting            ZatcaSetting?
  zatcaInvoiceLogs        ZatcaInvoiceLog[]
  employeeRecords         EmployeeRecord[]
  pushSubscriptions       PushSubscription[]

  @@index([slug])
  @@index([isActive])
  @@map("companies")
}

model CompanyMembership {
  id                  String   @id @default(cuid())
  userId              String
  companyId           String
  branchId            String?
  role                RoleType @default(STAFF)
  permissionOverrides Json?    @default("{}")
  isActive            Boolean  @default(true)
  joinedAt            DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch  Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@index([branchId])
  @@map("company_memberships")
}

model EmployeeRecord {
  id              String   @id @default(cuid())
  companyId       String
  branchId        String?
  userId          String?  @unique
  name            String
  email           String?
  phone           String?
  jobTitle        String?
  department      String?
  employmentType  String   @default("FULL_TIME")
  hasSystemAccess Boolean  @default(false)
  isActive        Boolean  @default(true)
  joinedAt        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch  Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([branchId])
  @@index([userId])
  @@index([isActive])
  @@map("employee_records")
}

model Branch {
  id        String    @id @default(cuid())
  name      String
  code      String
  phone     String?
  email     String?
  address   String?
  city      String?
  companyId String
  isDefault Boolean   @default(false)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  memberships     CompanyMembership[]
  employeeRecords EmployeeRecord[]
  warehouses      Warehouse[]
  sales           Sale[]
  purchases       Purchase[]
  inventoryLogs   InventoryLog[]

  @@unique([code, companyId])
  @@index([companyId])
  @@index([isActive])
  @@map("branches")
}

model Warehouse {
  id                String    @id @default(cuid())
  name              String
  code              String
  type              StoreType @default(MAIN_WAREHOUSE)
  branchId          String?
  assignedEmployeeId String?
  companyId         String
  isDefault         Boolean   @default(false)
  isActive          Boolean   @default(true)
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  company          Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch           Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  assignedEmployee User?               @relation("WarehouseAssignedEmployee", fields: [assignedEmployeeId], references: [id], onDelete: SetNull)
  productStocks    ProductStock[]
  locations        WarehouseLocation[]
  sales            Sale[]
  purchases        Purchase[]
  inventoryLogs    InventoryLog[]
  productLotStocks ProductLotStock[]

  @@unique([code, companyId])
  @@index([companyId])
  @@index([branchId])
  @@index([assignedEmployeeId])
  @@index([isActive])
  @@map("warehouses")
}

model WarehouseLocation {
  id              String    @id @default(cuid())
  name            String
  code            String
  type            String    @default("INTERNAL") // VIEW, INTERNAL, INPUT, OUTPUT, QUALITY, PACKING, TRANSIT, INVENTORY_LOSS
  warehouseId     String
  companyId       String
  parentId        String?
  barcode         String?
  removalStrategy String?
  isReplenishable Boolean   @default(false)
  isScrapLocation Boolean   @default(false)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  company   Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouse Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  parent    WarehouseLocation?  @relation("WarehouseLocationTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  WarehouseLocation[] @relation("WarehouseLocationTree")

  @@unique([code, companyId])
  @@index([companyId])
  @@index([warehouseId])
  @@index([parentId])
  @@index([type])
  @@map("warehouse_locations")
}

model Invitation {
  id          String           @id @default(cuid())
  email       String
  companyId   String
  role        RoleType         @default(STAFF)
  token       String           @unique
  status      InvitationStatus @default(PENDING)
  invitedById String
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedBy User    @relation("InvitationSentBy", fields: [invitedById], references: [id])

  @@index([token])
  @@index([email])
  @@index([companyId])
  @@map("invitations")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String?
  description String?
  color       String?
  icon        String?
  companyId   String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([name, companyId])
  @@index([companyId])
  @@map("categories")
}

model Unit {
  id           String    @id @default(cuid())
  name         String
  abbreviation String    @default("")
  companyId    String
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([name, companyId])
  @@index([companyId])
  @@map("units")
}

model Product {
  id             String              @id @default(cuid())
  name           String
  sku            String?
  barcode        String?
  description    String?
  purchasePrice  Decimal             @default(0)
  sellingPrice   Decimal             @default(0)
  wholesalePrice Decimal?
  stock          Int                 @default(0)
  minStock       Int                 @default(0)
  maxStock       Int?
  unit           String              @default("pcs")
  tax            Decimal             @default(0)
  discount       Decimal             @default(0)
  image          String?
  isActive       Boolean             @default(true)
  isService      Boolean             @default(false)
  trackingMode   ProductTrackingMode @default(NONE)
  mfgDate        DateTime?
  expiryDate     DateTime?
  categoryId     String?
  companyId      String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  deletedAt      DateTime?

  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category       Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  saleItems      SaleItem[]
  purchaseItems  PurchaseItem[]
  inventoryLogs  InventoryLog[]
  stockLocations ProductStock[]
  lots           ProductLot[]
  lotStocks      ProductLotStock[]
  quotationItems QuotationItem[]

  @@unique([sku, companyId])
  @@index([companyId])
  @@index([categoryId])
  @@index([name])
  @@index([barcode])
  @@map("products")
}

model ProductStock {
  id          String   @id @default(cuid())
  productId   String
  warehouseId String
  companyId   String
  quantity    Int      @default(0)
  minStock    Int      @default(0)
  maxStock    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
  @@index([companyId])
  @@index([warehouseId])
  @@map("product_stocks")
}

model ProductLot {
  id           String    @id @default(cuid())
  productId    String
  companyId    String
  lotNumber    String
  serialNumber String?
  expiryDate   DateTime?
  notes        String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  product       Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  company       Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stocks        ProductLotStock[]
  inventoryLogs InventoryLog[]

  @@unique([productId, lotNumber, companyId])
  @@unique([productId, serialNumber, companyId])
  @@index([companyId])
  @@index([productId])
  @@index([expiryDate])
  @@map("product_lots")
}

model ProductLotStock {
  id          String   @id @default(cuid())
  lotId       String
  productId   String
  warehouseId String
  companyId   String
  quantity    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lot       ProductLot @relation(fields: [lotId], references: [id], onDelete: Cascade)
  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([lotId, warehouseId])
  @@index([companyId])
  @@index([productId])
  @@index([warehouseId])
  @@map("product_lot_stocks")
}

model Customer {
  id             String    @id @default(cuid())
  name           String
  email          String?
  phone          String?
  address        String?
  city           String?
  companyName    String?
  taxId          String?
  notes          String?
  creditLimit    Decimal   @default(0)
  openingBalance Decimal   @default(0)
  totalPurchases Decimal   @default(0)
  companyId      String
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sales              Sale[]
  payments           Payment[]
  ledger             LedgerEntry[]
  reminders          PaymentReminder[]
  balanceAdjustments BalanceAdjustment[]
  commitments        PaymentCommitment[]
  quotations         Quotation[]

  @@index([companyId])
  @@index([phone])
  @@map("customers")
}

model Supplier {
  id             String    @id @default(cuid())
  name           String
  email          String?
  phone          String?
  address        String?
  city           String?
  companyName    String?
  taxId          String?
  notes          String?
  totalSales     Decimal   @default(0)
  openingBalance Decimal   @default(0)
  companyId      String
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchases          Purchase[]
  payments           Payment[]
  ledger             LedgerEntry[]
  reminders          PaymentReminder[]
  balanceAdjustments BalanceAdjustment[]
  commitments        PaymentCommitment[]

  @@index([companyId])
  @@map("suppliers")
}

model Sale {
  id            String            @id @default(cuid())
  invoiceNumber String
  subtotal      Decimal           @default(0)
  discount      Decimal           @default(0)
  tax           Decimal           @default(0)
  total         Decimal           @default(0)
  paid          Decimal           @default(0)
  due           Decimal           @default(0)
  status        SaleStatus        @default(COMPLETED)
  paymentStatus SalePaymentStatus @default(UNPAID)
  paymentMethod PaymentMethod     @default(CASH)
  notes         String?
  terms         String?
  dueDate       DateTime?
  customerId    String?
  companyId     String
  branchId      String?
  warehouseId   String?
  createdById   String
  updatedById   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?

  // Tax compliance fields
  taxComplianceMode     String  @default("NONE") // NONE, FBR, ZATCA
  taxComplianceStatus   String? // NOT_VERIFIED, VERIFIED, FAILED
  fbrInvoiceNumber      String? // FBR IRN
  fbrQrPayload          String? // FBR QR verification data
  zatcaQrPayload        String? // ZATCA TLV Base64 payload
  zatcaPhase            String? // PHASE_1, PHASE_2
  zatcaInvoiceHash      String? // ZATCA invoice hash (Phase 2)
  zatcaSubmissionStatus String? // NOT_CONFIGURED, CONFIGURED, SUBMITTED, CLEARED, REPORTED, FAILED
  zatcaUuid             String? // ZATCA assigned UUID
  zatcaXmlPath          String? // Stored UBL XML path
  zatcaResponseJson     Json? // Full ZATCA API response
  sellerTaxNumber       String? // Supplier NTN / VAT reg
  buyerTaxNumber        String? // Customer NTN / VAT reg

  company                   Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch                    Branch?                    @relation(fields: [branchId], references: [id], onDelete: SetNull)
  warehouse                 Warehouse?                 @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  customer                  Customer?                  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdBy                 User                       @relation("SaleCreatedBy", fields: [createdById], references: [id])
  updatedBy                 User?                      @relation("SaleUpdatedBy", fields: [updatedById], references: [id])
  items                     SaleItem[]
  payments                  PaymentAllocation[]
  reconciliationAllocations ReconciliationAllocation[]
  quotations                Quotation[]
  zatcaInvoiceLogs          ZatcaInvoiceLog[]

  @@unique([invoiceNumber, companyId])
  @@index([companyId])
  @@index([branchId])
  @@index([warehouseId])
  @@index([customerId])
  @@index([createdAt])
  @@map("sales")
}

model SaleItem {
  id          String  @id @default(cuid())
  saleId      String
  productId   String
  quantity    Int     @default(1)
  price       Decimal @default(0)
  discount    Decimal @default(0)
  tax         Decimal @default(0)
  subtotal    Decimal @default(0)
  description String?

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model Purchase {
  id              String                @id @default(cuid())
  referenceNumber String
  subtotal        Decimal               @default(0)
  discount        Decimal               @default(0)
  tax             Decimal               @default(0)
  total           Decimal               @default(0)
  paid            Decimal               @default(0)
  due             Decimal               @default(0)
  status          PurchaseStatus        @default(PENDING)
  paymentStatus   PurchasePaymentStatus @default(UNPAID)
  paymentMethod   PaymentMethod         @default(CASH)
  notes           String?
  terms           String?
  dueDate         DateTime?
  supplierId      String?
  companyId       String
  branchId        String?
  warehouseId     String?
  createdById     String
  updatedById     String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  deletedAt       DateTime?

  company                   Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch                    Branch?                    @relation(fields: [branchId], references: [id], onDelete: SetNull)
  warehouse                 Warehouse?                 @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  supplier                  Supplier?                  @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdBy                 User                       @relation("PurchaseCreatedBy", fields: [createdById], references: [id])
  updatedBy                 User?                      @relation("PurchaseUpdatedBy", fields: [updatedById], references: [id])
  items                     PurchaseItem[]
  payments                  PaymentAllocation[]
  reconciliationAllocations ReconciliationAllocation[]

  @@unique([referenceNumber, companyId])
  @@index([companyId])
  @@index([branchId])
  @@index([warehouseId])
  @@index([supplierId])
  @@index([createdAt])
  @@map("purchases")
}

model PurchaseItem {
  id          String  @id @default(cuid())
  purchaseId  String
  productId   String
  quantity    Int     @default(1)
  price       Decimal @default(0)
  discount    Decimal @default(0)
  tax         Decimal @default(0)
  subtotal    Decimal @default(0)
  description String?

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@index([purchaseId])
  @@index([productId])
  @@map("purchase_items")
}

model InventoryLog {
  id           String   @id @default(cuid())
  productId    String
  companyId    String
  branchId     String?
  warehouseId  String?
  lotId        String?
  serialNumber String?
  type         String   @default("ADJUSTMENT") // SALE, PURCHASE, ADJUSTMENT, RETURN
  quantity     Int
  beforeStock  Int
  afterStock   Int
  reference    String? // invoice or PO number
  notes        String?
  createdById  String?
  createdAt    DateTime @default(now())

  product   Product     @relation(fields: [productId], references: [id])
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch    Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  warehouse Warehouse?  @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  lot       ProductLot? @relation(fields: [lotId], references: [id], onDelete: SetNull)
  createdBy User?       @relation("InventoryLogCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([companyId])
  @@index([branchId])
  @@index([warehouseId])
  @@index([lotId])
  @@index([createdById])
  @@index([createdAt])
  @@map("inventory_logs")
}

