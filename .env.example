# Database
DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/clouddaftar?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# Super Admin Bootstrap
SUPER_ADMIN_NAME="Your Name"
SUPER_ADMIN_EMAIL="owner@example.com"
SUPER_ADMIN_PASSWORD="change-this-password"

# OAuth Providers (optional - remove NEXT_PUBLIC_ prefix to enable server-side only)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"
NEXT_PUBLIC_GITHUB_CLIENT_ID="your-github-client-id"

# UploadThing
# UploadThing v7 uses one token for server uploads and the /api/uploadthing route.
UPLOADTHING_TOKEN="your-uploadthing-token"
# Legacy UploadThing apps may still expose these. Leave blank unless your dashboard needs them.
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# SMTP (for email invites, password reset)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="noreply@clouddaftar.com"

# Brevo SMTP (password recovery)
BREVO_SMTP_HOST="smtp-relay.brevo.com"
BREVO_SMTP_PORT=587
BREVO_SMTP_USER="your_brevo_smtp_login"
BREVO_SMTP_PASS="your_brevo_smtp_key"
MAIL_FROM_NAME="CloudDaftar Password Recovery"
MAIL_FROM_EMAIL="reset@cloud-daftar.com"

# Cron (for auto-renewal - set a random secret and configure an external cron job hitting /api/cron/auto-renew)
CRON_SECRET="your-cron-secret-change-in-production"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Cloud Daftar"
NEXT_PUBLIC_THERMAL_PRINT_BRIDGE_URL=""

# PDF rendering
# Local/dev only. On Vercel, set CHROMIUM_PACK_URL to a Chromium bundle hosted on
# Vercel (e.g., from @sparticuz/chromium) for puppeteer-core PDF generation.
CHROMIUM_PACK_URL="https://example.com/chromium-v123.0.0-pack.tar"
PUPPETEER_EXECUTABLE_PATH=""

# ZATCA Simulation SDK (optional; requires Java on PATH)
ZATCA_SDK_CLI_PATH=""
ZATCA_SDK_HOME=""
ZATCA_SDK_VALIDATE_XML_ARGS="-validate -invoice {xml}"
